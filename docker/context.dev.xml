              url="jdbc:mysql://db:3306/openclinic_dbo?useSSL=false&amp;allowPublicKeyRetrieval=true&amp;characterEncoding=UTF-8&amp;zeroDateTimeBehavior=convertToNull&amp;sessionVariables=sql_mode='NO_ENGINE_SUBSTITUTION'"
